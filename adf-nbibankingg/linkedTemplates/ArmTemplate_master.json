{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-nbibankingg"
		},
		"ls_blob_source_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_blob_source'"
		},
		"ls_sql_dw_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sql_dw'"
		},
		"ls_key_vault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-nbi-banking.vault.azure.net/"
		},
		"ls_sql_dw_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "db-nbi-dw.database.windows.net"
		},
		"ls_sql_dw_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqldb-nbi-dw"
		},
		"ls_sql_dw_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "SQLAdmin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-nbibankingg_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_blob_source_connectionString": {
						"value": "[parameters('ls_blob_source_connectionString')]"
					},
					"ls_sql_dw_password": {
						"value": "[parameters('ls_sql_dw_password')]"
					},
					"ls_key_vault_properties_typeProperties_baseUrl": {
						"value": "[parameters('ls_key_vault_properties_typeProperties_baseUrl')]"
					},
					"ls_sql_dw_properties_typeProperties_server": {
						"value": "[parameters('ls_sql_dw_properties_typeProperties_server')]"
					},
					"ls_sql_dw_properties_typeProperties_database": {
						"value": "[parameters('ls_sql_dw_properties_typeProperties_database')]"
					},
					"ls_sql_dw_properties_typeProperties_userName": {
						"value": "[parameters('ls_sql_dw_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "adf-nbibankingg_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-nbibankingg_ArmTemplate_0')]"
			]
		}
	]
}