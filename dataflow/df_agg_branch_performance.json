{
	"name": "df_agg_branch_performance",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Dim_accounts",
						"type": "DatasetReference"
					},
					"name": "sourcedimaccounts"
				},
				{
					"dataset": {
						"referenceName": "Dim_fact_loans",
						"type": "DatasetReference"
					},
					"name": "sourcefactloans"
				},
				{
					"dataset": {
						"referenceName": "Dim_fact_transactions",
						"type": "DatasetReference"
					},
					"name": "sourcefacttransactions"
				},
				{
					"dataset": {
						"referenceName": "Dim_customers",
						"type": "DatasetReference"
					},
					"name": "sourcedimcustomers"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "agg_branch_performance",
						"type": "DatasetReference"
					},
					"name": "sinkbranchperformance"
				}
			],
			"transformations": [
				{
					"name": "joincustomeraccount"
				},
				{
					"name": "joinloans"
				},
				{
					"name": "jointransactions"
				},
				{
					"name": "aggregatebranch"
				}
			],
			"scriptLines": [
				"source(output(",
				"          account_number as string,",
				"          customer_id as string,",
				"          account_type as string,",
				"          branch_id as string,",
				"          open_date as date,",
				"          close_date as date,",
				"          status as string,",
				"          currency as string,",
				"          interest_rate as decimal(5,2),",
				"          is_joint_account as boolean,",
				"          minimum_balance as decimal(10,2),",
				"          nominee_name as string,",
				"          missing_nominee_flag as boolean,",
				"          account_age_years as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> sourcedimaccounts",
				"source(output(",
				"          loan_id as string,",
				"          customer_id as string,",
				"          loan_type as string,",
				"          branch_id as string,",
				"          sanction_date as date,",
				"          disbursement_date as date,",
				"          maturity_date as date,",
				"          principal_amount as decimal(14,2),",
				"          outstanding_amount as decimal(14,2),",
				"          interest_rate as decimal(5,2),",
				"          tenure_months as integer,",
				"          emi_amount as decimal(12,2),",
				"          emi_due_date as integer,",
				"          total_emis_paid as integer,",
				"          emis_overdue as integer,",
				"          overdue_category as string,",
				"          collateral_type as string,",
				"          collateral_value as decimal(14,2),",
				"          loan_status as string,",
				"          loan_officer_id as string,",
				"          is_npa as boolean,",
				"          insurance_linked_flag as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> sourcefactloans",
				"source(output(",
				"          transaction_id as string,",
				"          account_number as string,",
				"          transaction_date as date,",
				"          transaction_time as timestamp,",
				"          transaction_type as string,",
				"          transaction_mode as string,",
				"          category as string,",
				"          channel as string,",
				"          amount as decimal(14,2),",
				"          currency as string,",
				"          status as string,",
				"          beneficiary_account as string,",
				"          beneficiary_name as string,",
				"          reference_number as string,",
				"          narration as string,",
				"          balance_after_txn as decimal(14,2),",
				"          is_suspicious as boolean,",
				"          is_internal_transfer as boolean,",
				"          meta_device_id as string,",
				"          meta_ip_address as string,",
				"          meta_location_city as string,",
				"          meta_processing_bank as string,",
				"          meta_batch_id as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> sourcefacttransactions",
				"source(output(",
				"          customer_id as string,",
				"          first_name as string,",
				"          last_name as string,",
				"          date_of_birth as date,",
				"          gender as string,",
				"          email as string,",
				"          mobile as string,",
				"          city as string,",
				"          state as string,",
				"          pincode as string,",
				"          customer_type as string,",
				"          occupation as string,",
				"          annual_income as decimal(14,2),",
				"          kyc_status as string,",
				"          registration_date as date,",
				"          branch_id as string,",
				"          relationship_manager_id as string,",
				"          pan_number as string,",
				"          credit_score as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> sourcedimcustomers",
				"sourcedimaccounts, sourcedimcustomers join(sourcedimaccounts@branch_id == sourcedimcustomers@branch_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joincustomeraccount",
				"joincustomeraccount, sourcefactloans join(sourcedimaccounts@branch_id == sourcefactloans@branch_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> joinloans",
				"joinloans, sourcefacttransactions join(sourcedimaccounts@account_number == sourcefacttransactions@account_number,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> jointransactions",
				"jointransactions aggregate(groupBy(sourcedimaccounts@branch_id),",
				"     {totalaccountsopened } = countIf(!isNull(sourcedimaccounts@account_number)),",
				"          {totalloanamount     } = sum(principal_amount),",
				"          {totaltransactions   } = count(transaction_id),",
				"          {avgcreditscore      } = avg(credit_score)) ~> aggregatebranch",
				"aggregatebranch sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          agg_id as integer,",
				"          branch_id as string,",
				"          city as string,",
				"          total_accounts_opened as integer,",
				"          total_active_accounts as integer,",
				"          total_loan_amount_disbursed as decimal(18,2),",
				"          total_active_loans as integer,",
				"          total_transactions as integer,",
				"          total_transaction_value as decimal(18,2),",
				"          avg_customer_credit_score as decimal(6,1),",
				"          total_npa_loans as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sinkbranchperformance"
			]
		}
	}
}