{
	"name": "df_dim_loan_types",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_blob_Json",
						"type": "DatasetReference"
					},
					"name": "loanssource"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Dim_loan_types",
						"type": "DatasetReference"
					},
					"name": "sinkloantypes"
				}
			],
			"transformations": [
				{
					"name": "selectloantype"
				},
				{
					"name": "aggregateloantype"
				}
			],
			"scriptLines": [
				"source(output(",
				"          loan_id as string,",
				"          customer_id as string,",
				"          loan_type as string,",
				"          branch_id as string,",
				"          sanction_date as string,",
				"          disbursement_date as string,",
				"          maturity_date as string,",
				"          principal_amount as double,",
				"          outstanding_amount as double,",
				"          interest_rate as double,",
				"          tenure_months as integer,",
				"          emi_amount as double,",
				"          emi_due_date as integer,",
				"          total_emis_paid as integer,",
				"          emis_overdue as integer,",
				"          collateral_type as string,",
				"          collateral_value as double,",
				"          loan_status as string,",
				"          loan_officer_id as string,",
				"          is_npa as integer,",
				"          insurance_linked as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     documentForm: 'arrayOfDocuments') ~> loanssource",
				"loanssource select(mapColumn(",
				"          loan_type",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectloantype",
				"selectloantype aggregate(groupBy(loan_type),",
				"     {loan_type } = first(loan_type)) ~> aggregateloantype",
				"aggregateloantype sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          loan_type_id as integer,",
				"          loan_type as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     truncate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sinkloantypes"
			]
		}
	}
}